---
---

<section class="final-cta" id="get-started">
  <div class="container">
    <div class="section-eyebrow">Get started</div>
    <h2 class="section-title">Two ways to roll out Infracost Dev</h2>
    <p class="section-sub">
      Install it on your own machine in five minutes, or talk to us about deploying it across your team.
    </p>

    <div class="final-cta-grid">
      <div class="cta-card dev">
        <div class="cta-card-accent"></div>
        <div class="cta-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M9 7L4 12L9 17M15 7L20 12L15 17" stroke="#22d3ee" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3>Set it up for yourself</h3>
        <p>
          Install the AI agent skill or IDE extension and get cost-aware IaC in your local
          workflow. Free to try, no credit card.
        </p>
        <a href="https://www.infracost.io/docs/" class="btn btn-secondary cta-btn">Read the docs</a>
      </div>

      <div class="cta-card admin">
        <div class="cta-card-accent"></div>
        <div class="cta-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M3 7C3 5.34 4.34 4 6 4H18C19.66 4 21 5.34 21 7V17C21 18.66 19.66 20 18 20H6C4.34 20 3 18.66 3 17V7Z" stroke="#f72585" stroke-width="1.6"/>
            <path d="M3 8L12 13L21 8" stroke="#f72585" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3>Set it up for your team</h3>
        <p>
          Roll out custom price books, FinOps policies, tagging standards, and more across every
          developer and repo in your org.
        </p>
        <a href="https://www.infracost.io/about/contact-us" class="btn btn-primary cta-btn">Contact us</a>
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta {
    padding: 96px 0 120px;
  }
  .final-cta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .cta-card {
    background: var(--panel);
    border: 1px solid var(--border-strong);
    border-radius: 16px;
    padding: 48px 40px;
    text-align: center;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
  }
  .cta-card:hover {
    border-color: var(--text-tertiary);
    transform: translateY(-4px);
  }
  .cta-card-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
  }
  .cta-card.dev .cta-card-accent {
    background: var(--cyan);
  }
  .cta-card.admin .cta-card-accent {
    background: var(--pink);
  }
  .cta-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: var(--sunken);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
  }
  .cta-card h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 26px;
    margin-bottom: 12px;
  }
  .cta-card p {
    font-size: 16px;
    color: var(--text-secondary);
    margin-bottom: 28px;
    line-height: 1.5;
  }
  .cta-btn {
    width: 100%;
  }

  @media (max-width: 900px) {
    .final-cta-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
