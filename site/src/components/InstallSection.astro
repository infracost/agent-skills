---
/**
 * InstallSection — "Up and running in 2 steps" installation guide.
 * Spec: 05-install-section.md
 *
 * Layout: steps left column, video right column on desktop (≥ 1024px).
 * Mobile: stacked vertically (steps → video).
 *
 * Decorative step numbers ("01", "02") are aria-hidden="true" — not headings.
 * Copy buttons use CodeBlock component with data-testid="copy-btn".
 * Sign-up link uses target="_blank" rel="noopener noreferrer" per spec.
 */
import CodeBlock from "./CodeBlock.astro";
import VideoPlaceholder from "./VideoPlaceholder.astro";
---

<section id="install" class="install-section" style="scroll-margin-top: var(--nav-height)">
  <div class="container install-inner">
    <!-- Left column: steps -->
    <div class="install-steps">
      <!-- Section header -->
      <div class="install-header">
        <p class="eyebrow">Get Started</p>
        <h2 class="install-heading">Up and running in 2&nbsp;steps</h2>
        <p class="install-subtext">
          Infracost AI is a native Claude Code skill. No new tools or CLIs — just two commands in Claude Code.
        </p>
      </div>

      <!-- Step 1 -->
      <div class="step">
        <span class="step-num" aria-hidden="true">01</span>
        <div class="step-content">
          <h3 class="step-title">Step 1 — Install the Infracost&nbsp;Marketplace</h3>
          <p class="step-desc">Open Claude Code and run the following plugin command:</p>
          <CodeBlock code="/plugin marketplace add infracost/agent-skills" />
        </div>
      </div>

      <!-- Step 2 -->
      <div class="step">
        <span class="step-num" aria-hidden="true">02</span>
        <div class="step-content">
          <h3 class="step-title">Step 2 — Install the Infracost&nbsp;Skills</h3>
          <p class="step-desc">
            Once the marketplace is installed, install the Infracost Skill (you'll need to restart Claude Code for the changes to take effect). Claude will guide you through connecting your Infracost account — your API key is configured automatically.
          </p>
          <CodeBlock code="/plugin install infracost@infracost" />
          <p class="step-note">
            Don't have an Infracost account?{" "}
            <a
              href="https://dashboard.infracost.io"
              target="_blank"
              rel="noopener"
              class="sign-up-link"
            >Sign up free →</a>
          </p>
        </div>
      </div>

      <!-- Reassurance + link to scenarios -->
      <p class="install-reassurance">
        That's it. Start your next IaC task in Claude and Infracost AI will be active automatically.
        <a href="#scenarios" class="explore-link">Explore what you can do →</a>
      </p>
    </div>

    <!-- Right column: video placeholder -->
    <div class="install-video-col">
      <div id="install-video" class="install-video-wrap">
          <div style="position: relative; padding-bottom: 56.25%; height: 0;"><iframe src="https://www.loom.com/embed/384f098220c142f29aa7ed5fe7e8ab65" frameborder="0" webkitallowfullscreen mozallowfullscreen allowfullscreen style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"></iframe></div>
      </div>
    </div>
  </div>
</section>

<style>
  .install-section {
    padding: var(--space-24) 0;
    background: var(--color-surface-alt);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .install-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .install-inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
      align-items: center;
    }
  }

  /* ─── Section header ─────────────────────────────────────────────── */
  .install-header {
    margin-bottom: var(--space-12);
  }

  .eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent-primary);
    margin-bottom: var(--space-3);
  }

  .install-heading {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .install-subtext {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 50ch;
  }

  /* ─── Step cards ─────────────────────────────────────────────────── */
  .install-steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .step {
    position: relative;
    display: flex;
    gap: var(--space-6);
    align-items: flex-start;
  }

  /* Decorative large step number — aria-hidden, purely visual.
     Uses full brand-secondary colour (no opacity) to achieve 3.04:1 contrast
     against --color-surface-alt, satisfying WCAG AA large-text threshold (3:1). */
  .step-num {
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 1;
    color: var(--color-accent-secondary);
    flex-shrink: 0;
    text-align: right;
    user-select: none;
    position: relative;
    top: -0.1em;
  }

  .step-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .step-title {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .step-desc {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .step-note {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
  }

  .sign-up-link {
    color: var(--color-accent-primary);
    text-decoration: none;
    font-weight: 500;
    transition: opacity var(--transition-fast);
  }

  .sign-up-link:hover {
    opacity: 0.8;
  }

  .sign-up-link:focus-visible {
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* ─── Reassurance + explore link ─────────────────────────────────── */
  .install-reassurance {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text-muted);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .explore-link {
    color: var(--color-accent-primary);
    font-weight: 500;
    text-decoration: none;
    font-size: var(--text-sm);
    transition: opacity var(--transition-fast);
  }

  .explore-link:hover {
    opacity: 0.8;
  }

  .explore-link:focus-visible {
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* ─── Video column ───────────────────────────────────────────────── */
  .install-video-col {
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .install-video-wrap {
    width: 100%;
    max-width: 640px;
  }

  @media (prefers-reduced-motion: reduce) {
    .sign-up-link,
    .explore-link {
      transition: none;
    }
  }
</style>
