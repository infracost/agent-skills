---
/**
 * TrustBar — Alpha-honest placeholder strip below the hero.
 * No real logos yet — slots invite early adopters to be first.
 * Spec: 07-social-proof.md, 10-alpha-trustbar.md
 */

const placeholders = [
  { label: "Your logo" },
  { label: "Here" },
  { label: "Seriously" },
  { label: "Be first" },
  { label: "← This spot" },
];
---

<section class="trust-bar" aria-label="Trusted by">
  <div class="container trust-bar-inner">
    <p class="trust-lead" data-trustbar-heading>Trusted by early believers</p>

    <ul class="logo-list" role="list">
      {placeholders.map((slot) => (
        <li class="logo-item">
          <div
            class="logo-placeholder"
            data-trust-placeholder
            aria-label={slot.label}
            role="img"
          >
            <span class="placeholder-label">{slot.label}</span>
          </div>
        </li>
      ))}
    </ul>

    <p class="trust-cta" data-trust-cta>
      You're one of the first. <a href="#install">Get your logo here →</a>
    </p>
  </div>
</section>

<style>
  .trust-bar {
    padding: var(--space-10) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .trust-bar-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .trust-lead {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .logo-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-4) var(--space-6);
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
  }

  .logo-item {
    display: flex;
    align-items: center;
  }

  /* Alpha placeholder — magenta dashed border signals intentional placeholder state */
  .logo-placeholder {
    height: 36px;
    width: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(220, 52, 182, 0.04);
    border: 2px dashed rgba(220, 52, 182, 0.3);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .placeholder-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    padding: 0 var(--space-2);
    max-width: 100%;
  }

  .trust-cta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
    width: 100%;
  }

  .trust-cta a {
    color: var(--color-accent-primary);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .trust-cta a:hover {
    color: var(--color-accent-primary);
  }
</style>
