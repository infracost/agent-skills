---
---

<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div>
        <div class="eyebrow">Introducing Infracost Dev</div>
        <h1>Cloud cost awareness for your <span class="accent">coding agent</span> or IDE</h1>
        <p class="hero-sub">
          Install in minutes and eliminate cloud waste from your IaC configurations — before you go to PR review.
        </p>
        <div class="hero-ctas">
          <a href="https://www.infracost.io/docs/" class="btn btn-primary">
            Get started free
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <div class="hero-trust">No credit card · 1,000+ services supported</div>
      </div>

      <div class="video-box" role="button" tabindex="0" aria-label="Play product demo">
        <div class="video-inner">
          <div class="play-btn">
            <svg width="24" height="28" viewBox="0 0 24 28" fill="none" aria-hidden="true">
              <path d="M22 14L0 27.8564L0 0.143593L22 14Z" fill="#fff"/>
            </svg>
          </div>
          <div>
            <div class="video-label">Demo · 2 min</div>
            <div class="video-title">See Infracost Dev in action</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 80px 0 96px;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .eyebrow {
    font-family: "Zalando Sans", serif;
    font-style: italic;
    font-weight: 400;
    font-size: 16px;
    color: var(--cyan);
    margin-bottom: 20px;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 56px;
    line-height: 1.07;
    letter-spacing: -0.01em;
    margin-bottom: 24px;
  }
  .hero h1 .accent {
    color: var(--pink);
  }
  .hero-sub {
    font-size: 20px;
    line-height: 1.5;
    color: var(--text-secondary);
    margin-bottom: 36px;
    max-width: 520px;
  }
  .hero-ctas {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .hero-trust {
    margin-top: 28px;
    font-size: 13px;
    color: var(--text-tertiary);
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .video-box {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--panel);
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .video-box:hover {
    border-color: var(--cyan);
    transform: translateY(-2px);
  }
  .video-box::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at center, rgba(124, 58, 237, 0.18), transparent 60%),
      linear-gradient(135deg, var(--panel) 0%, var(--sunken) 100%);
  }
  .video-inner {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }
  .play-btn {
    width: 76px;
    height: 76px;
    border-radius: 50%;
    background: var(--pink);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 8px rgba(247, 37, 133, 0.15);
    transition: transform 0.2s ease;
  }
  .video-box:hover .play-btn {
    transform: scale(1.06);
  }
  .play-btn svg {
    margin-left: 4px;
  }
  .video-label {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-secondary);
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .video-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    color: var(--text-primary);
    margin-top: 6px;
  }

  @media (max-width: 900px) {
    .hero {
      padding: 56px 0;
    }
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .hero h1 {
      font-size: 40px;
    }
  }
</style>

<script>
  document.querySelector(".video-box")?.addEventListener("keydown", (e) => {
    const ev = e as KeyboardEvent;
    if (ev.key === "Enter" || ev.key === " ") {
      ev.preventDefault();
      (ev.currentTarget as HTMLElement).click();
    }
  });
</script>
