---
/**
 * AlphaBanner — Fixed top-of-page alpha release announcement strip.
 * Renders above Nav and pushes it down via --banner-height CSS variable.
 * Spec: 09-alpha-hero-signal.md (Treatment 1)
 */
---

<div class="alpha-banner" data-alpha-banner>
  <p class="alpha-banner-text">
    🚧 Alpha release — expect rough edges. You've been warned (and we love you for it).
  </p>
</div>

<style>
  .alpha-banner {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-banner);
    background-color: rgba(26, 26, 46, 0.92); /* --color-surface at ~90% */
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-2) var(--space-4);
    overflow: hidden;
  }

  .alpha-banner-text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
    margin: 0;
    line-height: 1.5;
  }
</style>

<script>
  (function () {
    const maybeBannerEl = document.querySelector<HTMLElement>("[data-alpha-banner]");
    if (!maybeBannerEl) return;
    const bannerEl = maybeBannerEl;

    function setBannerHeight() {
      const h = bannerEl.getBoundingClientRect().height;
      document.documentElement.style.setProperty("--banner-height", `${h}px`);
    }

    if (typeof ResizeObserver !== "undefined") {
      const ro = new ResizeObserver(() => setBannerHeight());
      ro.observe(bannerEl);
    } else {
      window.addEventListener("resize", setBannerHeight, { passive: true });
    }
    setBannerHeight();

    // Re-measure after fonts load to ensure accurate height
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(() => setBannerHeight());
    }
  })();
</script>
