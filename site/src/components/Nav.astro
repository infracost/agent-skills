---
import GitHubStarsButton from "./GitHubStarsButton.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="https://www.infracost.io" class="logo" aria-label="Infracost Dev home">
      <img
        src={`${base}/images/infracost-logo.svg`}
        alt="Infracost"
        class="logo-img"
        width="151"
        height="26"
      />
      <span class="product-tag">Dev</span>
    </a>
    <div class="nav-links">
      <a href="#features">Features</a>
      <a href="#integrations">Integrations</a>
      <a href="https://www.infracost.io/docs/">Docs</a>
      <a href="https://www.infracost.io/pricing/">Pricing</a>

      <div class="nav-community">
        <GitHubStarsButton username="infracost" repo="infracost" />
        <a
          class="slack-btn"
          href="https://www.infracost.io/community-chat"
          target="_blank"
          rel="noreferrer"
          aria-label="Join our community Slack"
        >
          <img
            src={`${base}/images/icons/slack.svg`}
            alt=""
            width="16"
            height="16"
            class="slack-icon"
          />
          <span>Slack</span>
        </a>
      </div>

      <a href="https://www.infracost.io/docs/" class="btn btn-primary nav-cta">Get started free</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: rgba(13, 19, 44, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: var(--z-nav);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-primary);
  }
  .logo-img {
    display: block;
    height: 26px;
    width: auto;
  }
  .product-tag {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13px;
    color: var(--text-secondary);
    letter-spacing: 3px;
    text-transform: uppercase;
    padding-left: 12px;
    margin-left: 4px;
    border-left: 1px solid var(--border-strong);
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .nav-links a {
    color: var(--text-secondary);
    font-size: 15px;
  }
  .nav-links a:hover {
    color: var(--text-primary);
  }
  .nav-links .nav-cta {
    padding: 10px 18px;
    font-size: 14px;
    color: #fff;
  }

  .nav-community {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .slack-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    background: transparent;
    color: var(--text-primary) !important;
    font-family: var(--font-body);
    font-size: 14px !important;
    font-weight: 500;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      transform 0.15s ease;
  }
  .slack-btn:hover {
    background: var(--panel);
    border-color: var(--text-tertiary);
    color: var(--text-primary) !important;
    transform: translateY(-1px);
  }
  .slack-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .nav-links {
      display: none;
    }
  }
</style>
