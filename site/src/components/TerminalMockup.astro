---
/**
 * TerminalMockup — Stylized terminal window showing an example Infracost AI interaction.
 * Static-first rendering; optional typewriter reveal animation via CSS.
 * Under prefers-reduced-motion: animation is instant-complete (animation-duration: 0.01ms).
 * Spec: 04-hero-section.md
 */
---

<div class="terminal" data-terminal aria-label="Example Infracost AI interaction" role="img">
  <!-- Window chrome: three traffic-light dots -->
  <div class="terminal-chrome" aria-hidden="true">
    <span class="dot dot-red"></span>
    <span class="dot dot-yellow"></span>
    <span class="dot dot-green"></span>
  </div>

  <!-- Terminal content -->
  <div class="terminal-body">
    <div class="terminal-line terminal-prompt">
      <span class="prompt-cmd"> /plugin marketplace add infracost/agent-skills</span>
    </div>
    <div class="terminal-line terminal-prompt">
      <span class="prompt-cmd"> /plugin install infracost@infracost</span>
    </div>
    <div class="terminal-line terminal-prompt">
      <span class="prompt-cmd"> /exit </span><span class="muted-text">&nbsp;# you need to restart Claude Code</span>
    </div>
    <div class="terminal-output">
      <div class="terminal-line spacer"></div>
      <div class="terminal-line">
          <span class="info-text">Create a 3 tier web app on AWS using ECS & Postgres. It needs to be compliant with all of my organization's finops and tagging policies, and cost less than $100/mo</span>
      </div>

      <div class="terminal-line spacer"></div>
      <div class="terminal-line terminal-thinking">
        <span class="err-icon"><i class="ph-bold ph-spiral" aria-hidden="true"></i></span>
        <span class="err-text">&nbsp;Combobulating&hellip;</span>
      </div>

      <div class="terminal-line spacer"></div>
      <div class="terminal-line">
        <span class="arrow-icon">→</span>
        <span class="action-text"> Done...</span>
        <span class="success-text"> 5 resources created.</span>
      </div>

      <pre class="ascii-table"><span class="muted-text">
┌───────────────────────────────────┬────────┐
│</span><span class="info-text"> Resource                          </span><span class="muted-text">│</span><span class="info-text"> Cost   </span><span class="muted-text">│
├───────────────────────────────────┼────────┤
│</span><span class="action-text"> NAT Gateway                       </span><span class="muted-text">│</span><span class="action-text"> $32.85 </span><span class="muted-text">│
│</span><span class="action-text"> ECS Fargate (2 services, ARM64)   </span><span class="muted-text">│</span><span class="action-text"> $27.03 </span><span class="muted-text">│
│</span><span class="action-text"> ALB                               </span><span class="muted-text">│</span><span class="action-text"> $16.43 </span><span class="muted-text">│
│</span><span class="action-text"> RDS db.t4g.micro (gp3, single-AZ) </span><span class="muted-text">│</span><span class="action-text"> $13.98 </span><span class="muted-text">│
│</span><span class="action-text"> Secrets Manager                   </span><span class="muted-text">│</span><span class="action-text">  $0.40 </span><span class="muted-text">│
│</span><span class="info-text"> Total                             </span><span class="muted-text">│</span><span class="info-text"> $90.69 </span><span class="muted-text">│
└───────────────────────────────────┴────────┘</span></pre>
      <div class="terminal-line spacer"></div>
      <div class="terminal-line">
        <span class="info-icon"><i class="ph-bold ph-check-circle" aria-hidden="true"></i></span>
        <span class="success-text">&nbsp;Policy Compliance</span>
      </div>
      <div class="terminal-line">
        <span class="info-text"> All 14 policies pass. Key decisions made:</span>
      </div>
      <div class="terminal-line">
          <span class="info-text">- <strong>Graviton (ARM64)</strong> on ECS task definitions &amp; RDS (<span class="muted-text">db.t4g.micro</span>) &mdash; ~20% cheaper than x86</span>
      </div>

      <div class="terminal-line">
          <span class="info-text">- <strong>gp3 storage</strong> on RDS &mdash; 20% cheaper than gp2</span>
      </div>
      <div class="terminal-line">
        <span class="info-text">- <strong>Single-AZ RDS</strong> &mdash; for Dev, saves ~50% vs multi-AZ</span>
      </div>
      <div class="terminal-line">
        <span class="info-text">- <strong>HTTP &rarr; HTTPS redirect</strong> on ALB (ELB.1 compliance)</span>
      </div>
      <div class="terminal-line">
        <span class="info-text">- <strong>Secrets Manager</strong> for DB password &mdash; not env vars</span>
      </div>
      <div class="terminal-line">
          <span class="info-text">- <strong>RDS encryption at rest</strong> (<span class="muted-text">storage_encrypted = true</span>)</span>
      </div>
      <div class="terminal-line">
          <span class="info-text">- <strong><span class="muted-text">copy_tags_to_snapshot = true</span></strong> on RDS</span>
      </div>
      <div class="terminal-line">
        <span class="info-text">- <strong>CloudWatch log exports</strong> enabled on RDS</span>
      </div>
      <div class="terminal-line">
          <span class="info-text">- <strong><span class="muted-text">propagate_tags = &quot;TASK_DEFINITION&quot;</span></strong> on ECS services</span>
      </div>


    </div>
  </div>
</div>

<style>
  .terminal {
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    border-top: 2px solid var(--color-accent-secondary);
    border-radius: var(--radius-lg);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.6;
    overflow: hidden;
    box-shadow: var(--shadow-lg), 0 0 60px rgba(123, 71, 184, 0.15);
    /* Fixed dimensions prevent CLS on animation start */
    width: 100%;
    max-width: 560px;
  }

  /* Traffic-light chrome */
  .terminal-chrome {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid var(--color-border);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: var(--radius-full);
  }

  .dot-red    { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green  { background: #28c840; }

  /* Terminal body */
  .terminal-body {
    padding: var(--space-4) var(--space-6);
  }

  .terminal-line {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
  }

  .terminal-line.spacer {
    height: var(--space-3);
  }

  /* Prompt line */
  .prompt-char {
    color: var(--color-accent-secondary);
    font-weight: 700;
  }

  .prompt-cmd {
    color: var(--color-text);
  }

  /* Output tokens */
  .warn-icon  { color: #facc15; }
  .warn-text  { color: #fde68a; }

  .err-icon   { color: #f87171; }
  .err-text   { color: #f87171; }

  .muted-text { color: var(--color-text-muted); }

  .info-icon  { color: var(--color-accent-primary); }
  .info-text  { color: var(--color-text); }

  .arrow-icon   { color: var(--color-accent-secondary); font-weight: 700; }
  .action-text  { color: var(--color-text-muted); }
  .success-text { color: var(--color-success); font-weight: 600; }

  .ascii-table {
    margin: 0;
    padding: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

</style>

<script>
  (function () {
    var body = document.querySelector('[data-terminal] .terminal-body') as HTMLElement | null;
    if (!body) return;


    var CHAR_DELAY = 18;

    // Collect all animatable elements: prompt lines, then output children (flattened)
    var items: HTMLElement[] = [];
    var bodyChildren = Array.from(body.children) as HTMLElement[];
    for (var b = 0; b < bodyChildren.length; b++) {
      var el = bodyChildren[b];
      if (el.classList.contains('terminal-output')) {
        // Flatten output children into the sequence
        var outputChildren = Array.from(el.children) as HTMLElement[];
        for (var c = 0; c < outputChildren.length; c++) {
          items.push(outputChildren[c]);
        }
      } else {
        items.push(el);
      }
    }

    // Lock the terminal height before hiding items to prevent layout shift
    var terminal = body.closest('.terminal') as HTMLElement | null;
    if (terminal) terminal.style.minHeight = terminal.offsetHeight + 'px';

    // Hide everything up front via JS (avoids CSS scoping issues)
    for (var h = 0; h < items.length; h++) {
      items[h].style.visibility = 'hidden';
    }

    function sleep(ms: number) {
      return new Promise<void>(function (resolve) { setTimeout(resolve, ms); });
    }

    function typeLineChars(el: HTMLElement) {
      return new Promise<void>(function (resolve) {
        var original = el.innerHTML;
        var text = el.textContent || '';
        el.textContent = '';
        el.style.visibility = 'visible';
        var i = 0;
        var interval = setInterval(function () {
          if (i < text.length) {
            el.textContent += text[i];
            i++;
          } else {
            clearInterval(interval);
            el.innerHTML = original;
            resolve();
          }
        }, CHAR_DELAY);
      });
    }

    async function run() {
      for (var j = 0; j < items.length; j++) {
        var child = items[j];

        // Spacers: reveal instantly
        if (child.classList.contains('spacer')) {
          child.style.visibility = 'visible';
          continue;
        }

        // ASCII table: reveal as a single block
        if (child.classList.contains('ascii-table')) {
          child.style.visibility = 'visible';
          continue;
        }

        // Thinking line: type it out, then pulse smoothly for 2s
        if (child.classList.contains('terminal-thinking')) {
          await typeLineChars(child);
          child.style.setProperty('transition', 'opacity 0.4s ease-in-out', 'important');
          for (var p = 0; p < 4; p++) {
            child.style.opacity = '0.4';
            await sleep(500);
            child.style.opacity = '1';
            await sleep(500);
          }
          child.style.removeProperty('transition');
          continue;
        }

        // Regular lines (prompts + output): type character by character
        await typeLineChars(child);

        // Pause after the last prompt line before output begins
        if (child.classList.contains('terminal-prompt') &&
            j + 1 < items.length && !items[j + 1].classList.contains('terminal-prompt')) {
          await sleep(1000);
        }
      }
    }

    run();
  })();
</script>
