---
/**
 * ScenariosSection — "See it in action" use-case showcase.
 * Spec: 06-scenarios.md
 *
 * Contains the section heading/subheading and all 4 ScenarioBlock instances.
 * Alternating desktop layout (chess pattern) is applied via CSS :nth-child(even)
 * on .scenario-block wrappers — adding a 5th scenario requires zero CSS changes.
 *
 * Each scenario has a unique anchor ID: #scenario-01 … #scenario-04
 * (generated by ScenarioBlock from the `number` prop).
 *
 * Icons are inline SVG paths from Heroicons (MIT license).
 * Required paths:
 *   01 — tag/label
 *   02 — lightning bolt
 *   03 — currency dollar
 *   04 — shield-check
 */
import ScenarioBlock from "./ScenarioBlock.astro";

// Heroicons outline path data (MIT license — https://heroicons.com)
const icons = {
  tag: "M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3zM6 6h.008v.008H6V6z",
  bolt: "M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z",
  dollar:
    "M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  shield:
    "M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z",
};
---

<section id="scenarios" class="scenarios-section" style="scroll-margin-top: var(--nav-height)">
  <!-- Section intro -->
  <div class="container scenarios-intro">
    <p class="eyebrow">Use Cases</p>
    <h2 class="scenarios-heading">See it in action</h2>
    <p class="scenarios-subheading">
        Infracost AI understands your infrastructure.<br/>Here's what that&nbsp;unlocks.
    </p>
  </div>

  <!-- Scenario blocks container — :nth-child(even) reversal applied here -->
  <div class="scenarios-container">
    <!--
      Alternating layout (chess pattern):
      Odd blocks  → text left, video right (DOM order)
      Even blocks → video left, text right (CSS :nth-child(even) reversal below)
      Adding a 5th scenario requires zero CSS changes.
    -->
    <ScenarioBlock
      number="01"
      title="Spot every tagging gap across your infrastructure"
      tagline="You can't fix what you can't see."
      description="Untagged or incorrectly tagged resources create cost attribution gaps, compliance violations, and blind spots in your FinOps reporting. Infracost AI scans your entire IaC codebase and surfaces every resource missing required tags — before they ever get deployed."
      bullets={[
        "Identifies all resources missing required tag keys",
        "Highlights which tags are wrong, missing, or inconsistently applied",
        "Shows the cost and compliance impact of each gap",
        "Works across Terraform, Terragrunt, and OpenTofu",
      ]}
      videoLabel="See: tagging audit walkthrough"
      embedUrl="https://www.loom.com/embed/b4f7bc94dda54ae7b0b67ff4e2fe6dd1"
      icon={icons.tag}
    />

    <ScenarioBlock
      number="02"
      title="Fix tagging violations 100× faster"
      tagline="From audit to compliant in seconds, not sprints."
      description="When Infracost AI finds a tagging issue, it doesn't just report it — it fixes it. Tell Claude what your required tag standards are, and it applies them across every affected resource in one shot. What used to take days of manual Terraform editing now takes a single command."
      bullets={[
        "Auto-generates tag fixes for all flagged resources",
        "Applies your organization's tag standards (team, env, cost-center, etc.)",
        "Shows a diff before applying any changes",
        "Handles complex modules and nested resources",
      ]}
      videoLabel="See: auto-fix tagging violations"
      embedUrl="https://www.loom.com/embed/79be3192f2374882a2ada3c7f7a2f30e"
      icon={icons.bolt}
    />

    <ScenarioBlock
      number="03"
      title="Adjust resources to fit within budget"
      tagline="Ship more within budget, not less."
      description="Got a cost threshold to hit? Tell Infracost AI your budget and it'll analyze your current resource configuration, identify the highest-impact changes, and suggest rightsizing options — while explaining the performance trade-offs of each change."
      bullets={[
        "Analyzes current monthly cost against your stated budget",
        "Identifies top cost drivers and rightsizing opportunities",
        "Suggests specific instance type or tier changes",
        "Estimates new monthly cost after each change",
      ]}
      videoLabel="See: budget optimization in action"
      icon={icons.dollar}
    />

    <ScenarioBlock
      number="04"
      title="Generate new infrastructure that's compliant from the&nbsp;start"
      tagline="Zero surprises at review time."
      description="Ask Infracost AI to write Infrastructure as Code (IaC) for a new service, and it generates code that's already within your budget, tagged correctly, and compliant with your org's standards — on the first attempt. No back-and-forth with your FinOps team."
      bullets={[
        "Generates Infrastructure as Code with required tags pre-applied",
        "Selects instance types that fit within your cost constraints",
        "Validates against your org's policy rules before output",
        "Dramatically reduces FinOps review cycles",
      ]}
      videoLabel="See: compliant IaC generation"
      icon={icons.shield}
    />
  </div>
</section>

<style>
  .scenarios-section {
    padding-top: var(--space-24);
    border-top: 1px solid var(--color-border);
  }

  /* ─── Section intro ────────────────────────────────────────────────── */
  .scenarios-intro {
    text-align: center;
    max-width: 680px;
    margin-inline: auto;
    padding-bottom: var(--space-16);
  }

  .eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent-primary);
    margin-bottom: var(--space-3);
  }

  .scenarios-heading {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .scenarios-subheading {
    font-size: var(--text-lg);
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  /* ─── Scenarios container ──────────────────────────────────────────── */
  .scenarios-container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  @media (min-width: 640px) {
    .scenarios-container {
      padding-inline: var(--space-8);
    }
  }

  @media (min-width: 1024px) {
    .scenarios-container {
      padding-inline: var(--space-12);
    }
  }

  /* ─── Alternating layout (chess pattern) ──────────────────────────────
     Use :global() to cross the ScenarioBlock component boundary.
     Odd blocks  → text left, video right (DOM order — no override needed).
     Even blocks → video left, text right (order: -1 on the video column).
     Adding a 5th or 6th scenario requires zero CSS changes here.
     Spec: 06-scenarios.md
     ────────────────────────────────────────────────────────────────────── */
  @media (min-width: 1024px) {
    .scenarios-container :global(.scenario-block:nth-child(even) [data-scenario-video]) {
      order: -1;
    }
  }
</style>
