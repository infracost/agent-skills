---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Quotes from "../components/Quotes.astro";
import Integrations from "../components/Integrations.astro";
import Features from "../components/Features.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Infracost Dev — Cloud cost awareness for your coding agent or IDE"
  description="Install in minutes and eliminate cloud waste from your IaC configurations — before you go to PR review."
>
  <Nav />
  <main id="main-content">
    <Hero />
    <Quotes />
    <Integrations />
    <Features />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
